@model Author
@{
    ViewData["Title"] = "Delete Author";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete Author</h1>

@if (Model != null)
{
    <h4>Are you sure you want to delete this author?</h4>
    <div>
        <dl class="row">
            <dt class="col-sm-2">Full Name</dt>
            <dd class="col-sm-10">@Model.FullName</dd>
        </dl>
    </div>

    @* Провери дали во контролерот акцијата е DeleteConfirmed *@
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
}
else
{
    <div class="alert alert-danger">Author not found.</div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
}