@model Book
@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Book Details</h1>

@if (Model != null)
{
    <div>
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Title</dd>

            <dt class="col-sm-2">ISBN</dt>
            <dd class="col-sm-10">@Model.ISBN</dd>

            <dt class="col-sm-2">Author</dt>
            <dd class="col-sm-10">@Model.Author?.FullName</dd>

            <dt class="col-sm-2">Available</dt>
            <dd class="col-sm-10">@(Model.IsAvailable ? "Yes" : "No")</dd>
        </dl>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-primary">Back</a>
}
else
{
    <div class="alert alert-warning">Book details not found.</div>
    <a asp-action="Index" class="btn btn-primary">Back to List</a>
}