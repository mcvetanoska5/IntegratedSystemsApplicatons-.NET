@model Book
@{
    ViewData["Title"] = "Delete Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete Book</h1>

@if (Model != null)
{
    <h4>Are you sure you want to delete this book?</h4>
    <div>
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Title</dd>

            <dt class="col-sm-2">ISBN</dt>
            <dd class="col-sm-10">@Model.ISBN</dd>

            <dt class="col-sm-2">Author</dt>
            <dd class="col-sm-10">@Model.Author?.FullName</dd>

            <dt class="col-sm-2">Available</dt>
            <dd class="col-sm-10">@(Model.IsAvailable ? "Yes" : "No")</dd>
        </dl>
    </div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
}
else
{
    <div class="alert alert-danger">Book not found.</div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
}