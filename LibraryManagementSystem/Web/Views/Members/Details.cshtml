@model Member
@{
    ViewData["Title"] = "Member Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Member Details</h1>

@if (Model != null)
{
    <div>
        <dl class="row">
            <dt class="col-sm-2">Full Name</dt>
            <dd class="col-sm-10">@Model.FullName</dd>
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@Model.Email</dd>
        </dl>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-primary">Back</a>
}
else
{
    <div class="alert alert-warning">Member details not found.</div>
    <a asp-action="Index" class="btn btn-primary">Back to List</a>
}