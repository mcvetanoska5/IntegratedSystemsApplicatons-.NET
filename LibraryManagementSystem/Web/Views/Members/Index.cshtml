@model IEnumerable<Member>
@{
    ViewData["Title"] = "Members";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Members</h1>
<a asp-action="Create" class="btn btn-success mb-3">Add New Member</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var member in Model)
            {
                <tr>
                    <td>@member.FullName</td>
                    <td>@member.Email</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@member.Id" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">No members found.</td>
            </tr>
        }
    </tbody>
</table>