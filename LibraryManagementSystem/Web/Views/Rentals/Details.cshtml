@model Rental
@{
    ViewData["Title"] = "Rental Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Rental Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Member</dt>
        <dd class="col-sm-10">
            @if (Model.Member != null)
            {
                @Model.Member.FullName
            }
            else
            {
                <span class="text-danger">Member Data Missing (ID: @Model.MemberId)</span>
            }
        </dd>
        <dt class="col-sm-2">Rented Books</dt>
        <dd class="col-sm-10">
            @if (Model.Books != null && Model.Books.Any())
            {
                foreach (var br in Model.Books)
                {
                    <div>
                        <strong>@(br.Book?.Title ?? "Unknown Book Title")</strong>
                        <span class="text-muted">- Rented At: @br.RentedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                }
            }
            else
            {
                <span class="text-warning">No book records found for this rental.</span>
            }
        </dd>
        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("dd/MM/yyyy")</dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-primary">Back to List</a>
</div>